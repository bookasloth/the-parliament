generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// 0. School & Org Structure
// ─────────────────────────────────────────────

model School {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(80)
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  houses    House[]
  divisions Division[]
  batches   Batch[]
  users     User[]
  groups    Group[]
  events    Event[]
  games     Game[]
  tournaments      Tournament[]
  rewardItems      RewardItem[]
  badges           Badge[]
  membershipPlans  MembershipPlan[]
  businessCategories BusinessCategory[]
  postCategories   PostCategory[]
  spotlights       Spotlight[]
  posts            Post[]
  businesses       Business[]
  karmaThresholds  KarmaThreshold[]

  @@map("schools")
}

model House {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  name       String   @db.VarChar(80)
  colorName  String   @map("color_name") @db.VarChar(30)
  colorHex   String   @map("color_hex") @db.Char(7)
  slogan     String?  @db.VarChar(200)
  isGirlsOnly Boolean @default(false) @map("is_girls_only")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  profiles Profile[]
  events   Event[]
  groups   Group[]

  @@unique([schoolId, name])
  @@map("houses")
}

model Division {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String   @db.VarChar(80)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userDivisions UserDivision[]

  @@unique([schoolId, name])
  @@map("divisions")
}

model Batch {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  startYear Int      @map("start_year")
  endYear   Int      @map("end_year")
  label     String   @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  profiles Profile[]
  groups   Group[]

  @@unique([schoolId, startYear])
  @@map("batches")
}

// ─────────────────────────────────────────────
// 1. Identity & Authentication
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String?   @map("school_id") @db.Uuid
  email           String    @db.VarChar()
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  username        String?   @unique @db.VarChar(60)
  mobileE164      String?   @map("mobile_e164") @db.VarChar(20)
  mobileVerifiedAt DateTime? @map("mobile_verified_at") @db.Timestamptz
  passwordHash    String?   @map("password_hash")
  legalName       String    @map("legal_name") @db.VarChar(160)
  displayName     String    @default("") @map("display_name") @db.VarChar(120)
  memberType      String    @default("alumni") @map("member_type") @db.VarChar(20)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?   @db.VarChar(20)
  currentClass    Int?      @map("current_class")
  yearsStudied    Int?      @map("years_studied")
  currentStatus   String?   @map("current_status") @db.VarChar(20)
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at") @db.Timestamptz
  status          String    @default("active") @db.VarChar(20)
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz
  onboardingStep   String   @default("profile") @map("onboarding_step") @db.VarChar(30)
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  profileCompletion Int     @default(0) @map("profile_completion")
  verificationStatus String @default("pending") @map("verification_status") @db.VarChar(20)
  membershipStatus String   @default("free") @map("membership_status") @db.VarChar(20)
  membershipExpiresAt DateTime? @map("membership_expires_at") @db.Timestamptz
  verificationData   Json?     @map("verification_data")
  membershipData     Json?     @map("membership_data")
  connectionsData    Json?     @map("connections_data")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  profile Profile?
  credentials UserCredential[]
  sessions UserSession[]
  mfaFactors MfaFactor[]
  verificationTokens VerificationToken[]
  alumniVerifications AlumniVerification[]
  userRoles UserRole[]
  userDivisions UserDivision[]
  reactions Reaction[]
  contentReports ContentReport[]
  conversations ConversationParticipant[]
  eventsHosted Event[] @relation("event_host")
  guardianConsents GuardianConsent[]
  userKarma UserKarma?
  karmaTransactions KarmaTransaction[]
  karmaDailyCounters KarmaDailyCounter[]
  karmaPairActor KarmaPairDay[] @relation("karma_actor")
  karmaPairTarget KarmaPairDay[] @relation("karma_target")
  connectionsRequested Connection[] @relation("connection_requester")
  connectionsReceived Connection[] @relation("connection_addressee")
  blocksGiven UserBlock[] @relation("blocker")
  blocksReceived UserBlock[] @relation("blocked")
  posts Post[]
  comments Comment[]
  postShares PostShare[]
  eventRsvps EventRsvp[]
  eventAttendance EventAttendance[]
  eventFeedback EventFeedback[]
  businesses Business[]
  businessReviews BusinessReview[]
  memberships Membership[]
  payments Payment[]
  donations Donation[]
  groupMembers GroupMember[]
  gameScores GameScore[]
  matchParticipants MatchParticipant[]
  tournamentEntries TournamentEntry[]
  activityEvents ActivityEvent[]
  userBadges UserBadge[]
  karmaRedemptions KarmaRedemption[]
  sentMessages  Message[]      @relation("message_sender")
  savedPosts    SavedPost[]
  postAwards    PostAward[]
  pollVotes     PollVote[]
  notifications Notification[]
  interests     UserInterest[]
  onboardingProgress OnboardingProgress[]

  @@unique([email])
  @@index([status])
  @@index([schoolId])
  @@index([memberType])
  @@map("users")
}

model UserCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  provider     String    @db.VarChar(40)
  providerUid  String    @map("provider_uid") @db.VarChar(255)
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("user_credentials")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?
  ipInet           String?   @map("ip_inet")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  rotatedFrom      String?   @map("rotated_from") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedRef UserSession?  @relation("SessionRotation", fields: [rotatedFrom], references: [id])
  rotations  UserSession[] @relation("SessionRotation")

  @@index([userId])
  @@unique([refreshTokenHash])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ─────────────────────────────────────────────
// 1b. Interests & Onboarding
// ─────────────────────────────────────────────

model Interest {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(80)
  slug      String   @unique @db.VarChar(80)
  icon      String?  @db.VarChar(40)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  users UserInterest[]

  @@index([slug])
  @@map("interests")
}

model UserInterest {
  userId     String   @map("user_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
  @@map("user_interests")
}

model OnboardingProgress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  step      String   @default("profile") @db.VarChar(30)
  data      Json     @default("{}")
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

model MfaFactor {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String    @db.VarChar(20)
  secretEnc   String?   @map("secret_enc")
  confirmedAt DateTime? @map("confirmed_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_factors")
}

model VerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  purpose    String    @db.VarChar(30)
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// 2. Profile
// ─────────────────────────────────────────────

model Profile {
  userId               String   @id @map("user_id") @db.Uuid
  photoUrl             String?  @map("photo_url")
  bio                  String?
  houseId              String?  @map("house_id") @db.Uuid
  batchId              String?  @map("batch_id") @db.Uuid
  department           String?  @db.VarChar(120)
  city                 String?  @db.VarChar(120)
  profession           String?  @db.VarChar(160)
  company              String?  @db.VarChar(160)
  industry             String?  @db.VarChar(120)
  designation          String?  @db.VarChar(160)
  higherEducation      String?  @map("higher_education") @db.VarChar(200)
  skills               Json     @default("[]")
  linkedinUrl          String?  @map("linkedin_url")
  headline             String?  @db.VarChar(200)
  socialLinks          Json     @default("{}") @map("social_links")
  whatsappOptIn        Boolean  @default(false) @map("whatsapp_opt_in")
  visibility           String   @default("alumni") @db.VarChar(20)
  isPublicIndexed      Boolean  @default(false) @map("is_public_indexed")
  showOnMap            Boolean  @default(false) @map("show_on_map")
  isComplete           Boolean  @default(false) @map("is_complete")
  contactAlwaysShare   Boolean  @default(false) @map("contact_always_share")
  connectionAutoAccept Boolean @default(false) @map("connection_auto_accept")
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  house House? @relation(fields: [houseId], references: [id])
  batch Batch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([city])
  @@index([company])
  @@map("profiles")
}

model UserDivision {
  userId     String   @map("user_id") @db.Uuid
  divisionId String   @map("division_id") @db.Uuid
  isProtected Boolean @default(false) @map("is_protected")
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  division Division @relation(fields: [divisionId], references: [id])

  @@id([userId, divisionId])
  @@index([divisionId])
  @@map("user_divisions")
}

// ─────────────────────────────────────────────
// 3. Alumni Verification
// ─────────────────────────────────────────────

model AlumniVerification {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  method         String    @db.VarChar(30)
  evidenceUrl    String?   @map("evidence_url")
  instituteEmail String?   @map("institute_email") @db.VarChar()
  status         String    @default("pending") @db.VarChar(20)
  reviewedBy     String?   @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamptz
  rejectReason   String?   @map("reject_reason")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("alumni_verifications")
}

// ─────────────────────────────────────────────
// 4. Authorization
// ─────────────────────────────────────────────

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  role      String   @db.VarChar(30)
  grantedBy String?  @map("granted_by") @db.Uuid
  grantedAt DateTime @default(now()) @map("granted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

// ─────────────────────────────────────────────
// 5. Social Graph
// ─────────────────────────────────────────────

model Connection {
  id               String    @id @default(uuid()) @db.Uuid
  requesterId      String    @map("requester_id") @db.Uuid
  addresseeId      String    @map("addressee_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  autoAccepted     Boolean   @default(false) @map("auto_accepted")
  contactExchanged Boolean   @default(false) @map("contact_exchanged")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  respondedAt      DateTime? @map("responded_at") @db.Timestamptz

  requester User @relation("connection_requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("connection_addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("connections")
}

model UserBlock {
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

// ─────────────────────────────────────────────
// 6. Posts, Comments, Reactions, Reports
// ─────────────────────────────────────────────

model PostCategory {
  id        String  @id @default(uuid()) @db.Uuid
  schoolId  String? @map("school_id") @db.Uuid
  key       String  @db.VarChar(40)
  label     String  @db.VarChar(80)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  school School? @relation(fields: [schoolId], references: [id])
  posts  Post[]

  @@unique([schoolId, key])
  @@map("post_categories")
}

model Post {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  authorId        String    @map("author_id") @db.Uuid
  groupId         String?   @map("group_id") @db.Uuid
  categoryId      String    @map("category_id") @db.Uuid
  format          String    @default("text") @db.VarChar(20)
  body            String?
  media           Json      @default("[]")
  linkUrl         String?   @map("link_url")
  visibilityScope String    @default("network") @map("visibility_scope") @db.VarChar(20)
  isPinned        Boolean   @default(false) @map("is_pinned")
  isEdited        Boolean   @default(false) @map("is_edited")
  editedAt        DateTime? @map("edited_at") @db.Timestamptz
  upvoteCount     Int       @default(0) @map("upvote_count")
  downvoteCount   Int       @default(0) @map("downvote_count")
  commentCount    Int       @default(0) @map("comment_count")
  shareCount      Int       @default(0) @map("share_count")
  qualityScore    Decimal   @default(0) @map("quality_score") @db.Decimal(8, 3)
  engagementScore Decimal   @default(0) @map("engagement_score") @db.Decimal(8, 3)
  reportPenalty   Decimal   @default(0) @map("report_penalty") @db.Decimal(8, 3)
  rankingScore    Decimal   @default(0) @map("ranking_score") @db.Decimal(10, 3)
  status          String    @default("visible") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  school School? @relation(fields: [schoolId], references: [id])
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  PostCategory @relation(fields: [categoryId], references: [id])
  group     Group?       @relation(fields: [groupId], references: [id])

  comments   Comment[]
  shares     PostShare[]
  mentions   PostMention[]
  savedBy    SavedPost[]
  awards     PostAward[]
  hashtags   PostHashtag[]
  poll       Poll?

  @@index([authorId])
  @@index([createdAt])
  @@index([categoryId])
  @@index([schoolId, rankingScore])
  @@index([schoolId, engagementScore])
  @@index([schoolId, isPinned])
  @@index([groupId, createdAt])
  @@map("posts")
}

model PostMention {
  id          String @id @default(uuid()) @db.Uuid
  postId      String @map("post_id") @db.Uuid
  mentionType String @map("mention_type") @db.VarChar(10)
  userId      String? @map("user_id") @db.Uuid
  houseId     String? @map("house_id") @db.Uuid
  batchId     String? @map("batch_id") @db.Uuid

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_mentions")
}

model PostShare {
  id             String   @id @default(uuid()) @db.Uuid
  originalPostId String   @map("original_post_id") @db.Uuid
  sharerId       String   @map("sharer_id") @db.Uuid
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  originalPost Post @relation(fields: [originalPostId], references: [id], onDelete: Cascade)
  sharer       User @relation(fields: [sharerId], references: [id], onDelete: Cascade)

  @@index([originalPostId])
  @@map("post_shares")
}

model Spotlight {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId        String?   @map("school_id") @db.Uuid
  subjectType String    @map("subject_type") @db.VarChar(12)
  subjectId   String    @map("subject_id") @db.Uuid
  headline    String?   @db.VarChar(200)
  curatedBy   String?   @map("curated_by") @db.Uuid
  activeFrom  DateTime  @default(now()) @map("active_from") @db.Timestamptz
  activeTo    DateTime? @map("active_to") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  school School? @relation(fields: [schoolId], references: [id])

  @@index([schoolId, activeFrom])
  @@map("spotlights")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  body      String
  likeCount Int       @default(0) @map("like_count")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   Comment? @relation("comment_parent", fields: [parentId], references: [id])
  children Comment[] @relation("comment_parent")

  @@index([postId])
  @@map("comments")
}

model Reaction {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(20)
  entityId   String   @map("entity_id") @db.Uuid
  type       String   @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("reactions")
}

model ContentReport {
  id         String    @id @default(uuid()) @db.Uuid
  reporterId String    @map("reporter_id") @db.Uuid
  entityType String    @map("entity_type") @db.VarChar(20)
  entityId   String    @map("entity_id") @db.Uuid
  reason     String    @db.VarChar(40)
  details    String?
  status     String    @default("open") @db.VarChar(20)
  resolvedBy String?   @map("resolved_by") @db.Uuid
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@unique([reporterId, entityType, entityId])
  @@map("content_reports")
}

// ─────────────────────────────────────────────
// 6b. Bookmarked Posts, Awards, Polls, Hashtags
// ─────────────────────────────────────────────

model SavedPost {
  userId  String   @map("user_id") @db.Uuid
  postId  String   @map("post_id") @db.Uuid
  savedAt DateTime @default(now()) @map("saved_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("saved_posts")
}

model PostAward {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  awardType String   @map("award_type") @db.VarChar(40)
  karmaCost Decimal  @map("karma_cost") @db.Decimal(8, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("post_awards")
}

model Poll {
  id         String    @id @default(uuid()) @db.Uuid
  postId     String    @unique @map("post_id") @db.Uuid
  question   String    @db.VarChar(500)
