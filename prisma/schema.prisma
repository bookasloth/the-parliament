  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameId, score])
  @@index([userId, playedAt])
  @@map("game_scores")
}

model GameMatch {
  id           String    @id @default(uuid()) @db.Uuid
  gameId       String    @map("game_id") @db.Uuid
  matchKind    String    @db.VarChar(12)
  tournamentId String?   @map("tournament_id") @db.Uuid
  status       String    @default("pending") @db.VarChar(12)
  startedAt    DateTime? @map("started_at") @db.Timestamptz
  endedAt      DateTime? @map("ended_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  game  Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id])
  participants MatchParticipant[]
  challenges   GameChallenge[]

  @@map("game_matches")
}

model MatchParticipant {
  matchId      String   @map("match_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  score        Int      @default(0)
  result       String?  @db.VarChar(12)
  karmaAwarded Decimal  @default(0) @map("karma_awarded") @db.Decimal(8, 2)

  match GameMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@map("match_participants")
}

model GameChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  gameId       String   @map("game_id") @db.Uuid
  challengerId String   @map("challenger_id") @db.Uuid
  opponentId   String?  @map("opponent_id") @db.Uuid
  status       String   @default("open") @db.VarChar(12)
  matchId      String?  @map("match_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  game Game      @relation(fields: [gameId], references: [id])
  match GameMatch? @relation(fields: [matchId], references: [id])

  @@map("game_challenges")
}

model Tournament {
  id           String    @id @default(uuid()) @db.Uuid
  schoolId     String    @map("school_id") @db.Uuid
  gameId       String?   @map("game_id") @db.Uuid
  name         String    @db.VarChar(160)
  season       String?   @db.VarChar(40)
  startsAt     DateTime  @map("starts_at") @db.Timestamptz
  endsAt       DateTime  @map("ends_at") @db.Timestamptz
  prizeBadgeId String?   @map("prize_badge_id") @db.Uuid
  prizeKarma   Decimal?  @map("prize_karma") @db.Decimal(8, 2)
  status       String    @default("upcoming") @db.VarChar(12)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  school School @relation(fields: [schoolId], references: [id])
  game   Game?  @relation(fields: [gameId], references: [id])
  entries TournamentEntry[]
  matches GameMatch[]

  @@map("tournaments")
}

model TournamentEntry {
  tournamentId String   @map("tournament_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  finalRank    Int?     @map("final_rank")
  karmaAwarded Decimal  @default(0) @map("karma_awarded") @db.Decimal(8, 2)
  joinedAt     DateTime @default(now()) @map("joined_at") @db.Timestamptz

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([tournamentId, userId])
  @@map("tournament_entries")
}

// ─────────────────────────────────────────────
// MODULES: Analytics / Action Log
// ─────────────────────────────────────────────

model ActivityEvent {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  eventType  String   @map("event_type") @db.VarChar(60)
  entityType String?  @map("entity_type") @db.VarChar(30)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json     @default("{}")
  ipInet     String?  @map("ip_inet")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("activity_events")
}
