# ── Core ───────────────────────────────────────────────────────────
# Local dev DB (docker compose -f docker/docker-compose.yml up -d).
# NOTE: in the production compose stack this is overridden to point at the
# `db` service, so you don't need to change it for deploy.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/the_parliament"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
# Local: http://localhost:3000 · Production: https://your-domain.org
AUTH_URL="http://localhost:3000"

# ── Deployment (production Docker stack) ───────────────────────────
# Your domain (no protocol). Caddy uses it to issue HTTPS automatically.
DOMAIN="your-domain.org"
# Postgres password for the bundled db container (use a strong value in prod).
POSTGRES_PASSWORD="postgres"
# Set true for the FIRST deploy so reference data + admin get seeded, then
# set back to false on subsequent deploys.
SEED_ON_START="false"

# ── Admin bootstrap ────────────────────────────────────────────────
# Comma-separated emails that are treated as admins on sign-in (no DB row
# needed — this is the "first admin" bootstrap allowlist).
ADMIN_EMAILS="you@example.com"
# Used by `npm run seed` (scripts/seed.ts) to create a credentials admin
# you can actually log in with. ADMIN_EMAIL defaults to the first ADMIN_EMAILS.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="ChangeMe123!"

# ── Google OAuth (optional) ────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Payments (Razorpay) ────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ── Email (SMTP / Nodemailer) ──────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@jnvnagpur.in"

# ── File storage (Cloudflare R2) ───────────────────────────────────
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
